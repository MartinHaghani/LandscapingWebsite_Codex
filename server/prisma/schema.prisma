generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadContactChannel {
  quote_finalize
  contact_form
}

enum LocationSource {
  address_geocode
  polygon_centroid_fallback
}

enum QuoteStatus {
  draft
  submitted
  in_review
  verified
  rejected
}

enum CustomerStatus {
  pending
  updated
  verified
  awaiting_payment
  rejected
}

enum ServiceFrequency {
  weekly
  biweekly
}

enum QuoteVersionChangeType {
  initial
  admin_revision
  pricing_override
  verification
}

enum QuoteVersionActorType {
  client
  admin
}

enum ServiceAreaRequestSource {
  out_of_area_page
  coverage_checker
  instant_quote
  contact_form
}

enum ServiceAreaRequestStatus {
  open
  reviewed
  planned
  rejected
}

enum AttributionTouchType {
  first_touch
  last_touch
  session_touch
  submit_snapshot
}

enum AuditActorRole {
  OWNER
  ADMIN
  REVIEWER
  MARKETING
  SYSTEM
}

enum IdempotencyScope {
  quote_draft
  quote_contact
  service_area_request
  contact_submit
}

model Lead {
  id               String               @id @default(cuid())
  primaryName      String?              @map("primary_name") @db.VarChar(120)
  primaryEmail     String?              @map("primary_email") @db.VarChar(160)
  primaryPhone     String?              @map("primary_phone") @db.VarChar(40)
  consentMarketing Boolean              @default(false) @map("consent_marketing")
  externalIds      Json?                @map("external_ids")
  firstSeenAt      DateTime             @default(now()) @map("first_seen_at")
  lastSeenAt       DateTime             @default(now()) @map("last_seen_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  contacts         LeadContact[]
  quotes           Quote[]
  serviceRequests  ServiceAreaRequest[]
  touches          AttributionTouch[]

  @@index([createdAt(sort: Desc)])
  @@map("leads")
}

model LeadContact {
  id          String             @id @default(cuid())
  leadId      String             @map("lead_id")
  channel     LeadContactChannel
  name        String?            @db.VarChar(120)
  email       String?            @db.VarChar(160)
  phone       String?            @db.VarChar(40)
  addressText String?            @map("address_text") @db.VarChar(300)
  message     String?
  createdAt   DateTime           @default(now()) @map("created_at")
  lead        Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt(sort: Desc)])
  @@map("lead_contacts")
}

model Quote {
  id                  String                @id @default(cuid())
  publicQuoteId       String                @unique @map("public_quote_id") @db.VarChar(32)
  leadId              String                @map("lead_id")
  authUserId          String?               @map("auth_user_id") @db.VarChar(255)
  addressText         String                @map("address_text") @db.VarChar(300)
  locationGeog        Unsupported("geography(Point,4326)")? @map("location_geog")
  locationSource      LocationSource        @default(address_geocode) @map("location_source")
  polygonGeom         Unsupported("geometry(MultiPolygon,4326)") @map("polygon_geom")
  polygonSourceJson   Json?                 @map("polygon_source_json")
  polygonCentroidGeog Unsupported("geography(Point,4326)")? @map("polygon_centroid_geog")
  areaM2              Decimal               @map("area_m2") @db.Decimal(14, 2)
  perimeterM          Decimal               @map("perimeter_m") @db.Decimal(14, 2)
  recommendedPlan     String                @map("recommended_plan") @db.VarChar(120)
  pricingVersion      String                @map("pricing_version") @db.VarChar(40)
  currency            String                @default("CAD") @db.VarChar(8)
  serviceFrequency    ServiceFrequency      @default(weekly) @map("service_frequency")
  sessionsMin         Int                   @default(26) @map("sessions_min")
  sessionsMax         Int                   @default(30) @map("sessions_max")
  perSessionTotal     Decimal               @map("per_session_total") @db.Decimal(14, 2)
  seasonalTotalMin    Decimal               @map("seasonal_total_min") @db.Decimal(14, 2)
  seasonalTotalMax    Decimal               @map("seasonal_total_max") @db.Decimal(14, 2)
  baseTotal           Decimal               @map("base_total") @db.Decimal(14, 2)
  finalTotal          Decimal               @map("final_total") @db.Decimal(14, 2)
  overrideAmount      Decimal?              @map("override_amount") @db.Decimal(14, 2)
  overrideReason      String?               @map("override_reason")
  status              QuoteStatus           @default(draft)
  customerStatus      CustomerStatus        @default(pending) @map("customer_status")
  contactPending      Boolean               @default(true) @map("contact_pending")
  assignedTo          String?               @map("assigned_to") @db.VarChar(128)
  teamId              String?               @map("team_id") @db.VarChar(128)
  submittedAt         DateTime?             @map("submitted_at")
  verifiedAt          DateTime?             @map("verified_at")
  verifiedBy          String?               @map("verified_by") @db.VarChar(128)
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  lead                Lead                  @relation(fields: [leadId], references: [id], onDelete: Restrict)
  versions            QuoteVersion[]
  notes               QuoteNote[]
  touches             AttributionTouch[]

  @@index([submittedAt(sort: Desc)])
  @@index([status, submittedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([authUserId, createdAt(sort: Desc)])
  @@map("quotes")
}

model QuoteVersion {
  id                  String                 @id @default(cuid())
  quoteId             String                 @map("quote_id")
  versionNumber       Int                    @map("version_number")
  changeType          QuoteVersionChangeType @map("change_type")
  actorType           QuoteVersionActorType  @default(client) @map("actor_type")
  polygonGeom         Unsupported("geometry(MultiPolygon,4326)") @map("polygon_geom")
  polygonSourceJson   Json?                  @map("polygon_source_json")
  polygonCentroidGeog Unsupported("geography(Point,4326)")? @map("polygon_centroid_geog")
  areaM2              Decimal                @map("area_m2") @db.Decimal(14, 2)
  perimeterM          Decimal                @map("perimeter_m") @db.Decimal(14, 2)
  recommendedPlan     String                 @map("recommended_plan") @db.VarChar(120)
  serviceFrequency    ServiceFrequency       @default(weekly) @map("service_frequency")
  sessionsMin         Int                    @default(26) @map("sessions_min")
  sessionsMax         Int                    @default(30) @map("sessions_max")
  perSessionTotal     Decimal                @map("per_session_total") @db.Decimal(14, 2)
  seasonalTotalMin    Decimal                @map("seasonal_total_min") @db.Decimal(14, 2)
  seasonalTotalMax    Decimal                @map("seasonal_total_max") @db.Decimal(14, 2)
  baseTotal           Decimal                @map("base_total") @db.Decimal(14, 2)
  finalTotal          Decimal                @map("final_total") @db.Decimal(14, 2)
  overrideAmount      Decimal?               @map("override_amount") @db.Decimal(14, 2)
  overrideReason      String?                @map("override_reason")
  changedBy           String                 @map("changed_by") @db.VarChar(128)
  changedAt           DateTime               @default(now()) @map("changed_at")
  quote               Quote                  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, versionNumber])
  @@index([quoteId, changedAt(sort: Desc)])
  @@map("quote_versions")
}

model QuoteNote {
  id        String   @id @default(cuid())
  quoteId   String   @map("quote_id")
  note      String
  createdBy String   @map("created_by") @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at")
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, createdAt(sort: Desc)])
  @@map("quote_notes")
}

model ServiceAreaRequest {
  id                         String                    @id @default(cuid())
  leadId                     String?                   @map("lead_id")
  addressText                String                    @map("address_text") @db.VarChar(300)
  locationGeog               Unsupported("geography(Point,4326)") @map("location_geog")
  isInServiceAreaAtCapture   Boolean                   @map("is_in_service_area_at_capture")
  distanceToNearestStationM  Decimal                   @map("distance_to_nearest_station_m") @db.Decimal(14, 2)
  source                     ServiceAreaRequestSource
  status                     ServiceAreaRequestStatus  @default(open)
  idempotencyKey             String                    @map("idempotency_key") @db.VarChar(120)
  createdAt                  DateTime                  @default(now()) @map("created_at")
  lead                       Lead?                     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@unique([idempotencyKey])
  @@index([createdAt(sort: Desc)])
  @@map("service_area_requests")
}

model AttributionTouch {
  id          String               @id @default(cuid())
  leadId      String?              @map("lead_id")
  quoteId     String?              @map("quote_id")
  touchType   AttributionTouchType @map("touch_type")
  gclid       String?              @db.VarChar(120)
  gbraid      String?              @db.VarChar(120)
  wbraid      String?              @db.VarChar(120)
  utmSource   String?              @map("utm_source") @db.VarChar(160)
  utmMedium   String?              @map("utm_medium") @db.VarChar(160)
  utmCampaign String?              @map("utm_campaign") @db.VarChar(200)
  utmTerm     String?              @map("utm_term") @db.VarChar(200)
  utmContent  String?              @map("utm_content") @db.VarChar(200)
  landingPath String?              @map("landing_path") @db.VarChar(300)
  referrer    String?              @db.VarChar(500)
  deviceType  String?              @map("device_type") @db.VarChar(40)
  browser     String?              @db.VarChar(80)
  geoCity     String?              @map("geo_city") @db.VarChar(120)
  createdAt   DateTime             @default(now()) @map("created_at")
  lead        Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quote       Quote?               @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([gclid])
  @@map("attribution_touches")
}

model AuditLog {
  id             String        @id @default(cuid())
  actorUserId    String?       @map("actor_user_id") @db.VarChar(128)
  actorRole      AuditActorRole @default(SYSTEM) @map("actor_role")
  action         String        @db.VarChar(120)
  entityType     String        @map("entity_type") @db.VarChar(80)
  entityId       String        @map("entity_id") @db.VarChar(128)
  changedFields  String[]      @default([]) @map("changed_fields")
  beforeRedacted Json?         @map("before_redacted")
  afterRedacted  Json?         @map("after_redacted")
  beforeFull     Json?         @map("before_full")
  afterFull      Json?         @map("after_full")
  requestId      String?       @map("request_id") @db.VarChar(120)
  correlationId  String?       @map("correlation_id") @db.VarChar(120)
  ipHash         String?       @map("ip_hash") @db.VarChar(128)
  userAgent      String?       @map("user_agent") @db.VarChar(300)
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model BaseStation {
  id              String   @id @default(cuid())
  internalLabel   String   @unique @map("internal_label") @db.VarChar(120)
  internalAddress String   @map("internal_address") @db.VarChar(300)
  locationGeog    Unsupported("geography(Point,4326)") @map("location_geog")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@map("base_stations")
}

model IdempotencyRecord {
  id            String           @id @default(cuid())
  scope         IdempotencyScope
  idempotencyKey String          @map("idempotency_key") @db.VarChar(120)
  requestHash   String           @map("request_hash") @db.VarChar(128)
  statusCode    Int              @map("status_code")
  responseJson  Json             @map("response_json")
  responseHash  String           @map("response_hash") @db.VarChar(128)
  resourceType  String?          @map("resource_type") @db.VarChar(80)
  resourceId    String?          @map("resource_id") @db.VarChar(128)
  createdAt     DateTime         @default(now()) @map("created_at")

  @@unique([scope, idempotencyKey])
  @@index([createdAt(sort: Desc)])
  @@map("idempotency_records")
}
